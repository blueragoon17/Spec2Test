{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blueragoon17/Spec2Test/schemas/unitverify.test-design.v1.schema.json",
  "title": "Language Independent Unit Verify Test Design",
  "type": "object",
  "required": ["schemaVersion", "testCases"],
  "properties": {
    "schemaVersion": { "const": "unitverify.test-design.v1" },
    "designId": { "type": "string" },
    "language": { "type": "string" },
    "source": { "type": "object", "additionalProperties": true },
    "testCases": {
      "type": "array",
      "items": { "$ref": "#/$defs/testCase" }
    },
    "manualTestCases": {
      "type": "array",
      "items": { "$ref": "#/$defs/testCase" }
    },
    "decisionTables": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "stateModels": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "boundaryValues": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "equivalencePartitions": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "undefinedBehaviorCorners": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "abnormalBehaviorCorners": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "testTechniqueSummary": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "createdAt": { "type": "string" }
  },
  "$defs": {
    "reviewStatus": {
      "enum": ["specified", "inferred", "missing", "needs_review", "approved", "rejected"]
    },
    "testCase": {
      "type": "object",
      "required": ["testcaseId", "reviewStatus"],
      "properties": {
        "testcaseId": { "type": "string" },
        "requirementId": { "type": "string" },
        "unitId": { "type": "string" },
        "name": { "type": "string" },
        "designMethod": {
          "enum": ["manual", "decision_table", "state_coverage", "boundary_value", "equivalence_partition", "coverage_growth", "undefined_behavior_corner", "abnormal_behavior_corner", "llm_inferred", "residual"]
        },
        "inputs": {},
        "oracleRef": { "type": "string" },
        "expected": {},
        "designReason": { "type": "string" },
        "sourceBasis": { "type": "string" },
        "executionCategory": { "type": "string" },
        "expectedRisk": { "type": "string" },
        "reviewStatus": { "$ref": "#/$defs/reviewStatus" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": { "type": "string" },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
