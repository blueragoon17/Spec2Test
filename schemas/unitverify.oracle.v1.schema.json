{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blueragoon17/Spec2Test/schemas/unitverify.oracle.v1.schema.json",
  "title": "Language Independent Unit Verify Oracles",
  "type": "object",
  "required": ["schemaVersion", "oracles"],
  "properties": {
    "schemaVersion": { "const": "unitverify.oracle.v1" },
    "oracleSetId": { "type": "string" },
    "language": { "type": "string" },
    "oracles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["oracleId", "reviewStatus"],
        "properties": {
          "oracleId": { "type": "string" },
          "testcaseId": { "type": "string" },
          "requirementId": { "type": "string" },
          "unitId": { "type": "string" },
          "expectedReturn": {},
          "expectedOutputs": {},
          "expectedState": {},
          "tolerance": { "type": "number" },
          "comparator": { "enum": ["exact", "numeric_tolerance", "regex", "contains", "custom"] },
          "sideEffects": { "type": "array" },
          "reviewStatus": { "$ref": "#/$defs/reviewStatus" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "reviewStatus": {
      "enum": ["specified", "inferred", "missing", "needs_review", "approved", "rejected"]
    }
  },
  "additionalProperties": true
}
