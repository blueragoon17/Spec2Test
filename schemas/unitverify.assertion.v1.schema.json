{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blueragoon17/Spec2Test/schemas/unitverify.assertion.v1.schema.json",
  "title": "Language Independent Unit Verify Assertions",
  "type": "object",
  "required": ["schemaVersion", "assertions"],
  "properties": {
    "schemaVersion": { "const": "unitverify.assertion.v1" },
    "assertionSetId": { "type": "string" },
    "language": { "type": "string" },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assertionId", "unitId", "kind", "reviewStatus"],
        "properties": {
          "assertionId": { "type": "string" },
          "requirementId": { "type": "string" },
          "unitId": { "type": "string" },
          "kind": { "enum": ["precondition", "postcondition", "invariant", "runtime_assertion", "safety_property"] },
          "expression": { "type": "string" },
          "location": { "type": "string" },
          "reviewStatus": { "$ref": "#/$defs/reviewStatus" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "reviewStatus": {
      "enum": ["specified", "inferred", "missing", "needs_review", "approved", "rejected"]
    }
  },
  "additionalProperties": true
}
