{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blueragoon17/Spec2Test/schemas/unitverify.traceability.v1.schema.json",
  "title": "Language Independent Unit Verify Traceability",
  "type": "object",
  "required": ["schemaVersion", "links"],
  "properties": {
    "schemaVersion": { "const": "unitverify.traceability.v1" },
    "traceabilityId": { "type": "string" },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirementId"],
        "properties": {
          "linkId": { "type": "string" },
          "requirementId": { "type": "string" },
          "designIds": { "type": "array", "items": { "type": "string" } },
          "testcaseIds": { "type": "array", "items": { "type": "string" } },
          "assertionIds": { "type": "array", "items": { "type": "string" } },
          "oracleIds": { "type": "array", "items": { "type": "string" } },
          "generatedArtifacts": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "coverage": { "type": "object", "additionalProperties": true },
          "result": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
