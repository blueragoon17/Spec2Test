{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blueragoon17/Spec2Test/schemas/perfectone.artifact-manifest.v1.schema.json",
  "title": "PerfectOne Artifact Manifest",
  "type": "object",
  "required": ["schemaVersion", "outDir", "artifacts"],
  "properties": {
    "schemaVersion": {
      "const": "perfectone.artifact-manifest.v1"
    },
    "outDir": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "relativePath", "type", "sizeBytes"],
        "properties": {
          "path": {
            "type": "string"
          },
          "relativePath": {
            "type": "string"
          },
          "type": {
            "enum": ["ir", "harness", "coverage", "testcase", "log", "json", "artifact", "function-report", "aggregate-report", "local-command", "diagnostic"]
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
