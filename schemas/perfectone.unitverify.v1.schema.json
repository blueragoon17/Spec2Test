{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blueragoon17/Spec2Test/schemas/perfectone.unitverify.v1.schema.json",
  "title": "PerfectOne Unit Verify Request",
  "type": "object",
  "required": ["schemaVersion", "language", "sourceFiles"],
  "properties": {
    "schemaVersion": {
      "const": "perfectone.unitverify.v1"
    },
    "projectRoot": {
      "type": "string"
    },
    "language": {
      "enum": ["c", "cpp"]
    },
    "sourceFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "compileDb": {
      "type": "string"
    },
    "environment": {
      "type": "object",
      "description": "Optional host/target OS and compiler context used by MCP to infer compile DB, toolchain prompts, and C coverage runner policy.",
      "properties": {
        "hostOs": { "enum": ["windows", "linux", "macos", "auto"] },
        "targetOs": { "enum": ["windows", "linux", "macos", "embedded", "baremetal", "rtos", "auto"] },
        "targetArch": { "type": "string" },
        "chip": { "type": "string" },
        "rtos": { "type": "string" },
        "sysroot": { "type": "string" },
        "compiler": { "type": "string" },
        "compilerPath": { "type": "string" },
        "toolchainPrefix": { "type": "string" },
        "cmakeToolchainFile": { "type": "string" },
        "includeDirs": { "type": "array", "items": { "type": "string" } },
        "libraryDirs": { "type": "array", "items": { "type": "string" } },
        "defines": { "type": "array", "items": { "type": "string" } },
        "compileArgs": { "type": "array", "items": { "type": "string" } },
        "linkArgs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "functions": {
      "type": "object",
      "properties": {
        "mode": {
          "enum": ["all", "name", "regex"]
        },
        "value": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "coverageGoal": {
      "type": "object",
      "properties": {
        "line": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "branch": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "mcdc": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "strategy": {
      "type": "array",
      "items": {
        "enum": ["klee", "native", "gtest", "cbmc", "libfuzzer"]
      },
      "uniqueItems": true
    },
    "outDir": {
      "type": "string"
    },
    "unitDesignArtifacts": {
      "type": "object",
      "description": "Optional language-independent unit design artifact references consumed by the C PerfectOne backend without changing the legacy request contract.",
      "properties": {
        "specAnalysis": { "type": "string" },
        "testDesign": { "type": "string" },
        "assertions": { "type": "string" },
        "oracles": { "type": "string" },
        "traceability": { "type": "string" },
        "review": { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
